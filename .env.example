# Frontend public variables.
# Configure only these two variables in Vercel for the React/Vite app.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional review-only helper route:
# - false: keeps /__evaluation hidden outside localhost
# - true: allows the technical evaluation panel in remote review environments
# For the evaluator flow in Vercel, set this to true so the logged-in user can
# open /__evaluation from the dashboard guide and seed the current workspace.
VITE_ENABLE_EVALUATION_PANEL=false

# Do not configure OPENAI_API_KEY or SUPABASE_SERVICE_ROLE_KEY in the Vercel frontend project.
# They must be configured as Supabase Edge Function secrets:
# npx supabase secrets set OPENAI_API_KEY=your-openai-api-key
# npx supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# Optional only for the heavy evaluation scenario. If omitted,
# npm run scenario:evaluation:crm uses the authenticated Supabase Edge Function
# with remote secrets.
OPENAI_API_KEY=your-openai-api-key

# Required local auth for both seeded commands.
TEST_USER_EMAIL=your-smoke-user-email
TEST_USER_PASSWORD=your-smoke-user-password

# Optional lightweight smoke configuration.
SMOKE_WORKSPACE_NAME=Operacao SDR Smoke
SMOKE_PUBLIC_BASE_URL=https://sdr-crm-ai-wine.vercel.app

# Optional heavy evaluation scenario configuration.
EVALUATION_WORKSPACE_NAME=Operacao SDR Avaliacao
EVALUATION_PUBLIC_BASE_URL=https://sdr-crm-ai-wine.vercel.app
EVALUATION_WAVE=all
EVALUATION_THREAD_LIMIT=75
EVALUATION_AI_DELAY_MS=500
